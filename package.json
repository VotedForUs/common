{
  "name": "@votedforus/common",
  "version": "1.0.9",
  "description": "Shared CI and tooling config for VotedForUs repos (semantic-release, gitmoji)",
  "type": "module",
  "scripts": {
    "extract:rules": "node scripts/extract-release-rules.mjs",
    "prepublishOnly": "npm run extract:rules"
  },
  "files": [
    "release-config.mjs",
    "release-config-npm.mjs",
    "release-rules.mjs",
    "release.config.mjs",
    "docs",
    "scripts"
  ],
  "exports": {
    ".": "./release-config.mjs",
    "./npm": "./release-config-npm.mjs"
  },
  "dependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "gitmojis": "^3.15.0",
    "semantic-release": "^25.0.3",
    "semantic-release-gitmoji": "^1.6.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VotedForUs/common.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
